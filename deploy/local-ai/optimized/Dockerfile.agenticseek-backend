# syntax=docker/dockerfile:1
# Octo-spork optimized AgenticSeek backend: multi-stage — compilers live only in the builder.
# Context: AgenticSeek repo root (same as upstream Dockerfile.backend).
# Target ~40%+ smaller than single-stage by dropping gcc/g++/build deps from the final layer.
#
# Platform note: Chrome URLs follow upstream linux64 defaults (amd64). Align with
# ``AGENTICSEEK_NATIVE_ARM64`` / ``_normalize_dockerfile_backend`` on Apple Silicon if needed.

FROM python:3.11.12-bookworm AS builder
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -y && apt-get install -y --no-install-recommends \
    wget gnupg2 ca-certificates unzip \
    gcc g++ gfortran \
    libportaudio2 portaudio19-dev \
    ffmpeg libavcodec-dev libavformat-dev libavutil-dev \
    libasound2 libatk-bridge2.0-0 libgtk-4-1 libnss3 xdg-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY requirements.txt .
RUN python -m venv /venv
RUN /venv/bin/pip install --no-cache-dir --upgrade pip setuptools wheel \
    && /venv/bin/pip install --no-cache-dir -r requirements.txt

# -----------------------------------------------------------------------------
# Runtime: slim Python + Chrome stack + venv (no compilers / no pip build tools).
# -----------------------------------------------------------------------------
FROM python:3.11.12-slim-bookworm AS runtime
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -y && apt-get install -y --no-install-recommends \
    wget gnupg2 ca-certificates unzip \
    xvfb libxss1 fonts-liberation libnss3 libatk1.0-0 libatk-bridge2.0-0 libcups2 \
    libdrm2 libxcomposite1 libxdamage1 libxrandr2 xdg-utils dbus \
    libportaudio2 \
    ffmpeg \
    libasound2 libgtk-4-1 \
    alsa-utils \
    python3 \
    && rm -rf /var/lib/apt/lists/*

ENV CHROME_TESTING_VERSION=134.0.6998.88
ENV DISPLAY=:99
WORKDIR /app

RUN set -eux; \
    wget -qO /tmp/chrome.zip \
    "https://storage.googleapis.com/chrome-for-testing-public/${CHROME_TESTING_VERSION}/linux64/chrome-linux64.zip"; \
    unzip -q /tmp/chrome.zip -d /opt; \
    rm /tmp/chrome.zip; \
    ln -sf /opt/chrome-linux64/chrome /usr/local/bin/google-chrome; \
    ln -sf /opt/chrome-linux64/chrome /usr/local/bin/chrome; \
    mkdir -p /opt/chrome; \
    ln -sf /opt/chrome-linux64/chrome /opt/chrome/chrome; \
    google-chrome --version

RUN set -eux; \
    wget -qO /tmp/chromedriver.zip \
    "https://storage.googleapis.com/chrome-for-testing-public/${CHROME_TESTING_VERSION}/linux64/chromedriver-linux64.zip"; \
    unzip -q /tmp/chromedriver.zip -d /tmp; \
    mv /tmp/chromedriver-linux64/chromedriver /usr/local/bin; \
    rm /tmp/chromedriver.zip; \
    chmod +x /usr/local/bin/chromedriver; \
    chromedriver --version

COPY --from=builder /venv /venv
ENV PATH="/venv/bin:$PATH"

COPY api.py .
COPY sources/ ./sources/
COPY prompts/ ./prompts/
COPY crx/ crx/
COPY llm_router/ llm_router/
COPY config.ini .

RUN mkdir -p /opt/workspace /tmp && chmod 1777 /tmp

EXPOSE 8000
CMD ["python3", "api.py"]
