# Local AI stack defaults for macOS host Ollama pattern.
# Copy this file to deploy/local-ai/.env.local and adjust values as needed.

# GitHub webhook bot ``GET /docs/context`` — last grounded-review Ollama prompt viewer (X-API-Key header).
# OCTO_SYSTEM_PROMPT_VIEWER_KEY=replace-me-with-a-long-random-secret

# Repository-local checkout of upstream AgenticSeek.
AGENTICSEEK_DIR=.local/agenticseek
AGENTICSEEK_REF=main

# Apple Silicon compatibility mode:
# - default: amd64 emulation for reliable AgenticSeek backend builds
# - optional: set AGENTICSEEK_NATIVE_ARM64=true + DOCKER_DEFAULT_PLATFORM=linux/arm64/v8 (experimental)
AGENTICSEEK_NATIVE_ARM64=false
# DOCKER_DEFAULT_PLATFORM=linux/amd64

# Keep Ollama on host (Metal on macOS) and let containers use host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LOCAL_URL=http://127.0.0.1:11434
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_MODEL=qwen2.5:14b
# NVIDIA GPU count for tooling / compose (host). Auto-maintained by: `./scripts/octo-spork doctor --fix`
# Apple Silicon / CPU-only hosts typically use 0.
# OLLAMA_NUM_GPU=1
# Integrator pre-flight: ping Ollama and ensure ``OLLAMA_MODEL`` exists in ``/api/tags`` before the LLM runs.
# Set ``OLLAMA_PREFLIGHT_REQUIRE_LOADED=true`` to also require the model in ``/api/ps`` (in-memory).
# OLLAMA_PREFLIGHT_TIMEOUT_SEC=8
# OLLAMA_PREFLIGHT_REQUIRE_LOADED=false
# Pull another tag without restarting Docker: ``python3 -m local_ai_stack swap-model --model llama3:8b --env-file deploy/local-ai/.env.local [--update-env]``

# AgenticSeek and companion service ports (avoid 3000 collision).
AGENTIC_FRONTEND_PORT=3010
AGENTIC_BACKEND_PORT=7777
BACKEND_PORT=7777
SEARXNG_PORT=8080
OPEN_WEBUI_PORT=3001
N8N_PORT=5678
# Postgres (optional ``addons`` / ``full`` compose profile). Host data: ``.local/data/postgres``.
# POSTGRES_PORT=5433
# POSTGRES_USER=octo
# POSTGRES_PASSWORD=replace-me-with-a-strong-password
# POSTGRES_DB=octo

# Optional host port for Redis when exposed (validated as an integer if set).
# REDIS_PORT=6379
#
# Claude Code session snapshot (local Redis): python runners can persist the last session id so
# developers can resume with ``./scripts/octo resume`` (``claude -r <id>``).
# REDIS_URL=redis://127.0.0.1:6379/0
# OCTO_RECORD_CLAUDE_SESSION=1
# OCTO_SESSION_REDIS_PREFIX=octo-spork:claude:last_session
# OCTO_SESSION_REDIS_TTL_SEC=2419200
#
# LangGraph session snapshots (agent_guard.session_store.SessionStore → local Redis):
# Keys default to octo-spork:langgraph:session:latest ; autosave every OCTO_SESSION_SAVE_INTERVAL_SEC (300s).
# OCTO_LANGGRAPH_SESSION_PREFIX=octo-spork:langgraph:session
# OCTO_LANGGRAPH_SESSION_TTL_SEC=604800
# OCTO_SESSION_SAVE_INTERVAL_SEC=300
# OCTO_SESSION_AUTOSAVE=1
#
# Resume: ./scripts/octo resume [--env-file deploy/local-ai/.env.local] [--workspace DIR]
#         ./scripts/octo resume --claude   # last Claude Code session id instead
#
# Global smell index (SQLite): recurring Trivy/CodeQL code-pattern hashes across repos/PRs.
# Database: .local/global_smell_index.db — override with OCTO_GLOBAL_SMELL_DB.
# OCTO_GLOBAL_SMELL_INDEX=1 (default) · OCTO_SPORK_SKIP_GLOBAL_SMELL=1 to disable ingestion.
#
# VRAM guard (run_agent, token_governor, octo resume, self-heal): blocks Claude when GPU VRAM
# utilization exceeds a threshold (nvidia-smi; system_profiler when used/total is present).
# Apple Silicon often lacks VRAM lines — set OCTO_VRAM_MAC_MEMORY_PROXY=1 for a coarse unified-memory heuristic.
# OCTO_VRAM_MAX_UTIL_PCT=90
# OCTO_SKIP_VRAM_GUARD=1
# OCTO_VRAM_MAC_MEMORY_PROXY=1
#
# OpenTelemetry → OTLP HTTP (Phoenix, OTEL Collector, LangSmith OTLP, etc.)
# ``pip install opentelemetry-*`` from requirements.txt when exporting traces.
# Example Phoenix (local): ``OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:6006/v1/traces``
# Example Collector: ``OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318`` (path ``/v1/traces`` appended if missing).
# OCTO_OTEL_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=octo-spork
# OCTO_OTEL_DISABLED=1
# OCTO_OTEL_MAX_BODY_CHARS=16384
#
# Fopoon dashboard trace tail + graceful kill (``./scripts/octo-fopoon-dashboard``):
# ``OCTO_TUI_TRACE_LOG`` — JSONL path appended by :mod:`observability.tracer` / ``tui_bridge``.
# ``OCTO_AGENT_STOP_FLAG`` — created when you press Kill (cooperative exit; does not delete Redis keys).
# OCTO_TUI_TRACE_LOG=.local/octo_fopoon_trace.jsonl
# OCTO_AGENT_STOP_FLAG=.local/octo_agent_stop_request
#
# SQLite audit trail (``logs/audit.db``): set ``OCTO_AUDIT_SQLITE=1`` and bind ``OCTO_AUDIT_SESSION_ID`` or
# call ``audit_sqlite.start_session()`` / ``set_audit_session()`` so mirrored trace rows persist.
# OCTO_AUDIT_DB=logs/audit.db
# OCTO_AUDIT_SQLITE=1
# OCTO_AUDIT_SESSION_ID=
#
# VRAM performance tracker (``observability.performance_tracker``): logs HW marks to ``logs/performance_vram.jsonl``;
# spikes emit ``logs/context_compression_events.jsonl`` + trim grounded-review evidence (see ``OCTO_PERF_*``).
# OCTO_PERF_DISABLE=1
# OCTO_PERF_TRACKING=1
# OCTO_PERF_STABILITY_UTIL_PCT=92
# OCTO_PERF_SPIKE_DELTA_MIB=3072
# OCTO_PERF_COMPRESSION_FILE_RATIO=0.65
# OCTO_PERF_COMPRESSION_CONTENT_RATIO=0.72
#
# Persistent Docker volumes for Redis (AgenticSeek base compose), Postgres, Open WebUI, and n8n
# are bind-mounted to ``<repo>/.local/data/{redis,postgres,open-webui,n8n}`` (see bootstrap patch + addons compose).

REACT_APP_BACKEND_URL=http://localhost:7777
BROWSER_COMMAND_TIMEOUT=300

# Outbound privacy guard (Linux; iptables in DOCKER-USER). Requires root/CAP_NET_ADMIN.
# When set to local-only, non-SearXNG stack containers may only reach private/link-local ranges;
# attempts to reach the public internet are logged, dropped, and can trigger an automatic `down`.
# LOCAL_AI_PRIVACY_MODE=local-only
# LOCAL_AI_PRIVACY_POLL_SECONDS=3
# LOCAL_AI_PRIVACY_VIOLATION_PKTS=1

# SearXNG: grounded repo reviews always use strict safe-search + query redaction (see overlays).
# Optionally force the same for all web_search tool calls (default off).
# OCTO_SPORK_STRICT_SEARX=false
# Optional comma-separated tokens stripped from outgoing SearXNG queries (PII-style redaction is always on in review).
# OCTO_SPORK_SEARCH_DENYLIST=

# Replace with strong random values in .env.local.
SEARXNG_SECRET_KEY=replace-me-with-a-random-secret
N8N_ENCRYPTION_KEY=replace-me-with-a-random-secret

# GitHub PAT for `python github_integrator.py` (repo scope: contents + pull requests).
# GITHUB_TOKEN=

# Webhook bot: comma-separated GitHub usernames allowed to trigger PR commands by commenting on the
# pull request (``issue_comment`` events): ``/octo-spork analyze`` or ``/octo-spork fix`` (remediation
# PR via local Claude Code). Others receive HTTP 403.
# ALLOWED_USERS=alice,bob
#
# Fix-it worker: requires ``AGENTICSEEK_DIR`` above, ``GITHUB_TOKEN``/``GH_TOKEN``, Docker, and the
# Claude agent stack. Optional: ``OCTO_FIX_SKIP_DOCKER=1`` (tests), ``OCTO_FIX_CLAUDE_TIMEOUT_SEC``,
# ``OCTO_SPORK_REPO_ROOT`` (path to this octo-spork checkout on the bot host).
#
# Review Refiner: pipe AI PR review text through local ``claude`` before posting. Enable with:
# ``OCTO_REVIEW_REFINER_ENABLED=true``. Requires ``claude`` on PATH (see ``run_agent`` sidecar).
# ``OCTO_REVIEW_REFINER_STRICT=1`` (default) withholds raw AI output if refinement fails.
# Webhook bot drafts: ``OCTO_PR_REVIEW_DRAFT`` (markdown) or ``OCTO_AI_FINDINGS_JSON_FILE`` (ReviewFormatter JSON).

# Claude Agent (optional): when ``deploy/claude-code/Dockerfile`` exists, ``python3 -m local_ai_stack up``
# builds and joins ``local-ai-claude-agent`` to ``agentic-seek-net`` with
# ``ANTHROPIC_BASE_URL=http://ollama:11434`` (host Ollama). Place secrets under ``.local/claude_config/.env``.
#
# Webhook PR worker: on processing errors, log full tracebacks and optionally append to a file or
# post a **Developer Note** to an internal issue (``owner/repo#number``). Requires ``GITHUB_TOKEN``
# for the issue comment. Use a private repo or restricted team issue for “private” notes.
# OCTO_SPORK_FAILURE_LOG=.local/octo-spork-pr-worker-failures.log
# OCTO_SPORK_DEVELOPER_NOTE_ISSUE=org/private-runbook#7

# Optional cloud provider keys for AgenticSeek backend.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
TOGETHER_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=
DSK_DEEPSEEK_API_KEY=
# Path mounted into backend at /opt/workspace for grounded repo reviews.
# macOS/Linux example: /home/you/repos
# Windows example (Docker Desktop): C:\Users\you\repos
WORK_DIR=/path/to/your/repos
GROUNDED_REPO_ROOT=/opt/workspace
# Optional grounded-review cache tuning (seconds).
GROUNDED_REVIEW_CACHE_TTL_SECONDS=900
GROUNDED_REVIEW_ANSWER_CACHE_TTL_SECONDS=600
# Diff Manager: when the full grounded-review synthesis prompt exceeds this budget (estimated tokens),
# split evidence into per-path-prefix chunks, run the LLM on each, then merge (optional final pass).
# GROUNDED_DIFF_CHUNKING_ENABLED=true
# GROUNDED_DIFF_CHUNK_PROMPT_TOKEN_THRESHOLD=8000
# GROUNDED_DIFF_MODULE_DEPTH=1
# GROUNDED_DIFF_MERGE_SYNTHESIS=true

# Optional grounded-review quality/perf tuning.
GROUNDED_REVIEW_ENABLE_TWO_PASS=true
GROUNDED_REVIEW_MAX_FILES=12
GROUNDED_REVIEW_MAX_TOTAL_BYTES=220000
GROUNDED_REVIEW_MAX_FILE_BYTES=80000
GROUNDED_REVIEW_NUM_CTX=14336
GROUNDED_REVIEW_NUM_CTX_TWO_PASS=12288
# When true, the model is instructed to reserve Critical severity for clearly evidenced issues (still LLM-judged).
GROUNDED_REVIEW_STRICT_COVERAGE=false
